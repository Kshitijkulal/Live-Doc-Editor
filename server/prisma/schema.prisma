generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  version   Int
  updatedAt DateTime @updatedAt
  updatedBy String? 
}